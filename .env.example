# Environment Variables for AI Meeting MOM Generator

# ─────────────────────────────────────────────
# NVIDIA NIM API Key (Primary LLM Backend)
# ─────────────────────────────────────────────
# Get your free API key at: https://build.nvidia.com
# The app uses meta/llama-3.1-70b-instruct by default.
NVIDIA_API_KEY=nvapi-YOUR_KEY_HERE

# ─────────────────────────────────────────────
# HuggingFace Token (Optional — for gated models)
# ─────────────────────────────────────────────
# Only needed if using gated HuggingFace models (Llama, Mistral gated variants).
# Get token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_YOUR_TOKEN_HERE

# ─────────────────────────────────────────────
# Groq API Key (Fast Audio Transcription)
# ─────────────────────────────────────────────
# Gets audio transcribed up to 40x faster than local CPU.
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_KEY_HERE